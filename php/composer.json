{
    "require": {
        "php": ">=8.0",
        "symfony/dotenv": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload-dev": {
        "psr-4": {
            "OntoMatchGame\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:db:up": "docker compose -f tests/docker-compose.yml up -d --wait --wait-timeout 90",
        "test:db:down": "docker compose -f tests/docker-compose.yml down"
    }
}
