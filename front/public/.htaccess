<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If an existing asset or directory is requested, serve it
  # (REQUEST_URI already includes the /ontomatchgame prefix)
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
  RewriteRule ^ - [L]

  # Otherwise, serve index.html for all routes
  RewriteRule ^ /ontomatchgame/index.html [L]
</IfModule>
