<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>

<IfModule mod_headers.c>
  # index.html, favicon and game content (json/, data/) are not fingerprinted
  # by the build, so browsers must always revalidate with the server before
  # reusing a cached copy. Otherwise a stale index.html keeps referencing
  # hashed asset filenames a new deploy has already removed, and users have
  # to hard-refresh to see the new version. /assets/ overrides this below.
  Header set Cache-Control "no-cache"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If an existing asset or directory is requested, serve it
  # (REQUEST_URI already includes the /ontomatchgame prefix)
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
  RewriteRule ^ - [L]

  # Otherwise, serve index.html for all routes
  RewriteRule ^ /ontomatchgame/index.html [L]
</IfModule>
