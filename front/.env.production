# Production Environment Configuration
# This file is used when running `npm run build`

# Base URL for the application (subdirectory deployment)
VITE_BASE_URL=/ontomatchgame/

# API endpoint for production
# Relative path: resolves against the page origin (https://dev.msh-vdl.fr),
# so it stays same-origin and avoids http/https mixed-content blocking.
VITE_API_BASE_URL=/ontomatchgame/php
